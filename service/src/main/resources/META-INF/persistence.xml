<persistence xmlns="http://java.sun.com/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd" version="2.0">
    <persistence-unit name="tracking-rest" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <!--non-jta-data-source>java:comp/env/jdbc/tracking</non-jta-data-source-->

        <class>com.tmw.tracking.entity.AuthenticatedUser</class>
        <class>com.tmw.tracking.entity.ContainerType</class>
        <class>com.tmw.tracking.entity.Driver</class>
        <class>com.tmw.tracking.entity.JobStatusInfo</class>
        <class>com.tmw.tracking.entity.Role</class>
        <class>com.tmw.tracking.entity.Permission</class>
        <class>com.tmw.tracking.entity.Terminal</class>
        <class>com.tmw.tracking.entity.Order</class>
        <class>com.tmw.tracking.entity.OrderDetails</class>
        <class>com.tmw.tracking.entity.TrackingSite</class>
        <class>com.tmw.tracking.entity.OrderWorkflow</class>
        <class>com.tmw.tracking.entity.User</class>
        <class>com.tmw.tracking.entity.TrackingLine</class>
        <class>com.tmw.tracking.entity.ContainerLocation</class>
        <class>com.tmw.tracking.entity.Company</class>
        <class>com.tmw.tracking.domain.flex.entities.Flex</class>
        <class>com.tmw.tracking.domain.flex.entities.FlexRename</class>
        <class>com.tmw.tracking.domain.flex.entities.FlexContainer</class>
        <class>com.tmw.tracking.domain.flex.entities.FlexWarehouse</class>
        <class>com.tmw.tracking.domain.flex.entities.FlexOrder</class>
        <class>com.tmw.tracking.domain.flex.entities.FlexHistory</class>
        <class>com.tmw.tracking.entity.ConfigurationEntity</class>

        <properties>
            <property name="hibernate.archive.autodetection" value="class, hbm" />
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLInnoDBDialect" />
            <property name="hibernate.connection.driver_class" value="com.mysql.cj.jdbc.Driver" />
            <property name="hibernate.connection.url" value="${connection.url}" />
            <property name="hibernate.connection.username" value="${connection.user}" />
            <property name="hibernate.connection.password" value="${connection.password}" />
            <!--property name="hibernate.hbm2ddl.auto" value="update" /-->
            <property name="hibernate.connection.characterEncoding" value="utf8"/>
            <property name="hibernate.c3p0.min_size" value="5"/>
            <property name="hibernate.c3p0.max_size" value="20"/>
            <property name="hibernate.c3p0.timeout" value="1800"/>
            <property name="hibernate.c3p0.max_statements" value="50"/>
            <property name="hibernate.connection.provider_class" value="org.hibernate.connection.C3P0ConnectionProvider"/>
            <property name="hibernate.c3p0.preferredTestQuery" value="SELECT 1"/>
            <property name="hibernate.c3p0.testConnectionOnCheckout" value="true"/>

            <property name="hibernate.search.default.directory_provider" value="filesystem"/>
            <property name="hibernate.search.default.indexBase" value="/tmp/sotrackc/indexes"/>
            <property name="hibernate.search.lucene_version" value="LUCENE_CURRENT"/>
            <!--property name="hibernate.search.default.indexwriter.max_merge_docs" value="100"/>
            <property name="hibernate.search.default.indexwriter.ram_buffer_size" value="64"/-->
            <property name="hibernate.search.default.exclusive_index_user" value="false"/>

            <!--
                        <property name="hibernate.hbm2ddl.auto" value="update" />
            -->
            </properties>
    </persistence-unit>
</persistence>
